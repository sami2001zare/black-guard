generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model ContactRequest {
  id        String   @id @default(cuid())

  fullName  String
  email     String?
  phone     String

  service   String?
  message   String?

  locale    String
  status    String   @default("new")

  createdAt DateTime @default(now())
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  name      String
  role      String   @default("admin")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}


model Media {
  id        String   @id @default(cuid())
  filename  String   // Original file name
  path      String   // Relative path e.g., "/uploads/abc123.jpg"
  mimeType  String
  size      Int
  alt       String?  // Optional alt text
  title     String?  // Optional title
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  services  Service[]
  teamMembers  TeamMember[]
//   abouts  About[]
}


model Service {
  id              String   @id @default(cuid())
  titleEn         String
  titleFa         String
  titleAr         String
  descriptionEn   String
  descriptionFa   String
  descriptionAr   String
  slug            String   @unique
  imageMediaId    String?
  imageMedia      Media?   @relation(fields: [imageMediaId], references: [id])
  published       Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([slug])
}


model Faq {
  id          String   @id @default(cuid())
  questionEn  String
  questionFa  String
  questionAr  String
  answerEn    String   // Rich text (HTML/TipTap)
  answerFa    String
  answerAr    String
  category    String?  // Optional category (e.g., "general", "security", "ceremonial")
  order       Int      @default(0)
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
  @@index([order])
}


model TeamMember {
  id          String   @id @default(cuid())
  nameEn      String
  nameFa      String
  nameAr      String
  roleEn      String
  roleFa      String
  roleAr      String
  credEn      String   // credentials (e.g., "Former Special Forces, 22 years")
  credFa      String
  credAr      String
  imageMediaId String?
  imageMedia  Media?   @relation(fields: [imageMediaId], references: [id])
  order       Int      @default(0)
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([order])
}


model About {
  id          String   @id @default(cuid())
  titleEn     String
  titleFa     String
  titleAr     String
  contentEn   String   // Rich text (HTML/TipTap)
  contentFa   String
  contentAr   String
//   imageMediaId String?
//   imageMedia  Media?   @relation(fields: [imageMediaId], references: [id])
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([published])
}