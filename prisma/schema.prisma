generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
//   url      = env("DATABASE_URL")
}

model ContactRequest {
  id        String   @id @default(cuid())

  fullName  String
  email     String?
  phone     String

  service   String?
  message   String?

  locale    String
  status    String   @default("new")

  createdAt DateTime @default(now())
}